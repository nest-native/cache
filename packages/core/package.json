{
  "name": "@stalefree/core",
  "version": "0.0.0",
  "description": "Framework-agnostic tag-based cache invalidation through the database you already have — in-memory L1, optional Drizzle L2, and an invalidation bus over Postgres LISTEN/NOTIFY (transactional: delivered on commit, dropped on rollback)",
  "keywords": [
    "cache",
    "cache-invalidation",
    "tags",
    "postgres",
    "listen-notify",
    "pg_notify",
    "no-redis",
    "stale-while-revalidate",
    "drizzle",
    "typescript"
  ],
  "author": "Rodrigo Nogueira",
  "license": "MIT",
  "homepage": "https://github.com/nest-native/cache#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nest-native/cache.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/nest-native/cache/issues"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./socket": {
      "types": "./dist/socket/index.d.ts",
      "require": "./dist/socket/index.js",
      "default": "./dist/socket/index.js"
    },
    "./postgres": {
      "types": "./dist/postgres/index.d.ts",
      "require": "./dist/postgres/index.js",
      "default": "./dist/postgres/index.js"
    },
    "./sqlite": {
      "types": "./dist/sqlite/index.d.ts",
      "require": "./dist/sqlite/index.js",
      "default": "./dist/sqlite/index.js"
    },
    "./mysql": {
      "types": "./dist/mysql/index.d.ts",
      "require": "./dist/mysql/index.js",
      "default": "./dist/mysql/index.js"
    }
  },
  "engines": {
    "node": ">=20"
  },
  "peerDependencies": {
    "drizzle-orm": "^0.44.0 || ^0.45.0"
  },
  "peerDependenciesMeta": {
    "drizzle-orm": {
      "optional": true
    }
  },
  "scripts": {
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {},
  "files": [
    "dist",
    "README.md"
  ]
}
