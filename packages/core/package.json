{
  "name": "@stalefree/core",
  "version": "0.0.0",
  "description": "Framework-agnostic tag-based cache invalidation through the database you already have — in-memory L1, optional Drizzle L2, and an invalidation bus over Postgres LISTEN/NOTIFY (transactional: delivered on commit, dropped on rollback)",
  "keywords": [
    "cache",
    "cache-invalidation",
    "tags",
    "postgres",
    "listen-notify",
    "pg_notify",
    "no-redis",
    "stale-while-revalidate",
    "drizzle",
    "typescript"
  ],
  "author": "Rodrigo Nogueira",
  "license": "MIT",
  "homepage": "https://github.com/nest-native/cache#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nest-native/cache.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/nest-native/cache/issues"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {},
  "files": [
    "dist",
    "README.md"
  ]
}
